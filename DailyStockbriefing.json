      "id": "cdb368d7-8c0b-471b-b1b7-bed93f3ed843",
      "name": "📰 News holen",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        704,
        32
      ]
    },
    {
      "parameters": {
        "jsCode": "const articles = $input.first().json.articles || [];\n\nconst summaries = articles.slice(0, 15).map(a => {\n  return `- ${a.title} (${a.source?.name || 'Unbekannt'}, ${new Date(a.publishedAt).toLocaleDateString('de-DE')})`;\n}).join('\\n');\n\nconst today = new Date().toLocaleDateString('de-DE', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });\n\nreturn [{\n  json: {\n    newsText: summaries || 'Keine aktuellen News gefunden.',\n    today: today\n  }\n}];"
      },
      "id": "ff88ae5b-b714-4211-a21c-05b2afac4917",
      "name": "🔧 News aufbereiten",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        928,
        32
      ]
    },
    {
      "parameters": {
        "jsCode": "const raw = $input.first().json.output || \"\";\n\n// Markdown-Backticks und \\n bereinigen\nconst clean = raw\n  .replace(/```html/g, \"\")\n  .replace(/```/g, \"\")\n  .replace(/\\\\n/g, \"\")\n  .trim();\n\nconst today = $('🔧 News aufbereiten').first().json.today;\n\nreturn [{\n  json: {\n    briefing: clean,\n    today: today,\n    subject: `📈 Dein Markt-Briefing – ${today}`\n  }\n}];"
      },
      "id": "927aca0d-7b24-4859-9fda-858215251bf8",
      "name": "📝 E-Mail vorbereiten",
